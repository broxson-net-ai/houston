# Database
DATABASE_URL=postgres://houston:houston@localhost:5432/houston

# Application
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-secure-random-string

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw Skills
OPENCLAW_SKILLS_PATH=/home/openclaw/.openclaw/workspace/skills

# Scheduler
DEFAULT_TIMEZONE=America/Los_Angeles
HOUSTON_DISPATCH_CONCURRENCY=5
HOUSTON_GRACE_WINDOW_SECONDS=300
HOUSTON_LOOKBACK_WINDOW_HOURS=48
HOUSTON_SCHEDULER_TICK_SECONDS=30

# Logs
MAX_LOG_BYTES=10485760
HOUSTON_LOG_RETENTION_DAYS=30
