{
  "name": "houston",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "concurrently \"npm run dev -w packages/web\" \"npm run dev -w packages/worker\"",
    "db:migrate": "npm run db:migrate -w packages/shared",
    "db:seed": "npm run db:seed -w packages/shared",
    "db:generate": "npm run db:generate -w packages/shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
